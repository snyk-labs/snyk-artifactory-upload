{
    "manifestVersion": 1,
    "id": "artifactory-upload",
    "name": "Snyk Artifactory Upload",
    "version": "0.0.999999",
    "publisher": "oleg-private-snyk",
    "targets": [
        {
            "id": "Microsoft.VisualStudio.Services"
        }
    ],    
    "description": "Set's properties on artifactory artifacts with result of snky SAST scan",
    "categories": [
        "Azure Pipelines"
    ],
    "files": [
        {
            "path": "buildandreleasetask"
        }
    ],
    "contributions": [
        {
            "id": "custom-build-release-task",
            "type": "ms.vss-distributed-task.task",
            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "buildandreleasetask"
            }
        }
    ]
}